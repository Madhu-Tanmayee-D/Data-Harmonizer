# Example Streamlit secrets for deployment
# Copy this to .streamlit/secrets.toml locally or set the same values in the Streamlit Cloud secrets UI.

[openai]
api_key = "sk-your-openai-key"
model = "gpt-4o-mini"
api_base = "https://api.openai.com/v1"
api_timeout = 30

[app]
environment = "production"
debug = false
